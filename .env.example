# Frontend / backend base URL (used for Mercado Pago redirect and webhooks)
APP_BASE_URL=http://localhost:3000

# Mercado Pago access token (use TEST-... in homolog and APP_USR-... in production)
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx

# Secret signature from Mercado Pago dashboard (Webhooks > Configurar notificações)
MP_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# Optional: explicit webhook URL. If omitted, server uses APP_BASE_URL + /api/mercadopago/webhooks?source_news=webhooks
# MP_NOTIFICATION_URL=https://your-domain.com/api/mercadopago/webhooks?source_news=webhooks

# Optional: max webhook timestamp drift in seconds
MP_WEBHOOK_TOLERANCE_SECONDS=300

# Optional (development only): skip x-signature validation
MP_WEBHOOK_SKIP_SIGNATURE_VALIDATION=false

# Backend port
PORT=4000

# Internal auth secret used to sign sessions (generate a long random value)
INTERNAL_AUTH_SECRET=change-me-with-a-long-random-secret

# Internal panel users (JSON string)
# Roles: admin | financeiro | suporte
INTERNAL_AUTH_USERS_JSON=[{"username":"admin","password":"change-me","role":"admin"},{"username":"financeiro","password":"change-me","role":"financeiro"}]

# Optional: session duration for internal users
INTERNAL_AUTH_SESSION_HOURS=12

# Legacy fallback user (optional, only if INTERNAL_AUTH_USERS_JSON is not set)
# INTERNAL_DASHBOARD_USER=admin
# INTERNAL_DASHBOARD_PASSWORD=change-me

# Optional CRM sync endpoint to update your license/user controls after payment events
# Example: https://seu-crm.vercel.app/api/payments/mercadopago/sync
CRM_SYNC_URL=

# Optional token to authorize SaaS -> CRM sync requests
CRM_SYNC_TOKEN=

# Optional timeout for CRM sync request in milliseconds
CRM_SYNC_TIMEOUT_MS=8000

# Optional: durable plan catalog persistence (recommended on Vercel)
# Reuses your existing Supabase project with service role key
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PLAN_TABLE=saas_plan_catalog
